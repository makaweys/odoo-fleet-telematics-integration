# Server Configuration
PORT=5000
NODE_ENV=development
USE_DUMMY_DATA=false

# MongoDB Configuration (optional - system has fallback)
MONGODB_URI=mongodb://127.0.0.1:27017/telematics?replicaSet=rs0

# WebSocket Configuration
SOCKET_PATH=/api/socket.io

# External Services (optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SMS Service (optional - from original code)
BULK_TEXTSMS_API_KEY=your_sms_api_key
BULK_TEXTSMS_PARTNER_ID=your_partner_id
PORT_CODE2=4308