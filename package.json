{
  "name": "odoo-fleet-telematics-integration",
  "version": "1.0.0",
  "description": "A real-time vehicle tracking system with geofencing, zone violation detection, and live location updates via WebSocket. Can be integrated with Odoo",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "simulator": "node src/jobs/vehicleSimulator.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "vehicle-tracking",
    "geofencing",
    "telematics",
    "real-time",
    "mongodb",
    "socket-io",
    "nodejs",
    "express",
    "violation-detection"
  ],
  "author": "Makaweys",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "geolib": "^3.3.4",
    "mongoose": "^8.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.53.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
